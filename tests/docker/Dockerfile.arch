FROM --platform=linux/amd64 archlinux:latest

ENV TERM=xterm-256color

# Add expected system users & groups
RUN useradd -r -s /usr/bin/nologin systemd-network 2>/dev/null || true
RUN groupadd -r systemd-journal 2>/dev/null || true

RUN sed -i '/^\[options\]/a DisableSandbox' /etc/pacman.conf

RUN pacman -Syu --noconfirm \
  && pacman -S --noconfirm --needed \
    bash \
    ca-certificates \
    curl \
    git \
    sudo \
  && pacman -Scc --noconfirm

# Create a non-root user to behave like a real machine
RUN useradd -m -s /bin/bash test \
  && echo "test ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/test \
  && chmod 0440 /etc/sudoers.d/test

# Bake dotfiles into the image (no runtime mount needed)
COPY --chown=test:test . /home/test/dotfiles

USER test
WORKDIR /home/test

RUN DOT_PULL_DOTFILES=0 DOT_RELOAD_SHELL=0 bash /home/test/dotfiles/setup/setup.sh

CMD ["/bin/bash"]
